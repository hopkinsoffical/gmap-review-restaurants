OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

SUPABASE_URL=
# Required for public leaderboard reads (/api/leaderboard/*) and browser Supabase Realtime (via /api/runtime-config).
SUPABASE_ANON_KEY=
# Required for admin writes, store ops, and SMS pipelines — not needed for public leaderboard list reads.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: Twilio Lookup v2 (Line Type Intelligence) for scripts/leaderboard_phone_sms_lookup.py — SMS capability labels for leaderboard phones.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# scripts/send_twilio_sms_batch.py — Twilio-owned sending number (E.164)
TWILIO_SMS_FROM=
# Optional: Twilio Messaging Service (Engagement Suite link shortening). Not required for funnel analytics — the app records report_view / engagement via POST /api/sms-funnel-events from the intel report page.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SHORTEN_URLS=false
# Optional: Twilio Link Shortening click callback. Only if you use shortened links in SMS; otherwise skip.
TWILIO_SKIP_LINK_CLICK_SIGNATURE=false
# SMS funnel: register outbound MessageSid → Supabase (same secret for /api/sms-funnel-stage)
SMS_FUNNEL_REGISTER_SECRET=
# Exposed to browser via /api/runtime-config — optional abuse mitigation for report_view beacon
# If set on the server, the browser must receive the SAME value from /api/runtime-config or POST /api/sms-funnel-events returns 403.
SMS_FUNNEL_BEACON_RUNTIME_TOKEN=
# Optional Slack / internal webhook for link_click, report_view, nurture_sent, manual stage (JSON POST)
SALES_ALERT_WEBHOOK_URL=
SALES_ALERT_WEBHOOK_SECRET=
# sql/027_sms_outreach_funnel.sql — session + events tables (includes pgcrypto + set_updated_at if missing)
# sql/029_sms_outreach_realtime.sql — add funnel tables to supabase_realtime publication (Realtime still needs RLS SELECT for your listener role; see file header)
# After changing SQL, run sql/013_salon_ai_leaderboard.sql then sql/014_seed_salon_ai_leaderboard.sql (or npm run generate:leaderboard-seed to regenerate 014).
# Then sql/015_leaderboard_preview_rls.sql (top-20 public preview + google_place_id).
# Then sql/016_leaderboard_drop_assessment_json.sql (UI tokens live in the app; DB keeps assessment_level only).
# Then sql/017_salon_ai_leaderboard_zipcode.sql (adds zipcode + index).
# Then sql/018_stores_google_place_id.sql (stores.google_place_id for Places tooling).
# Then sql/019_salon_ai_leaderboard_place_id.sql (leaderboard.place_id, kept in sync with google_place_id).
# If you already ran 015 when it used top 10, run sql/020_leaderboard_preview_top_20_rls.sql to bump RLS to top 20.
# sql/021_leaderboard_slug_history_latest_view.sql — history rows per slug + salon_ai_leaderboard_latest view + RLS helper.
# sql/034_restr_ai_leaderboard.sql — restaurant Google Visibility leaderboard (restr_ai_leaderboard + latest view + RLS).
# Batch ingest (same JSON: data/ai-leaderboard-source.json or AI_LEADERBOARD_SOURCE_PATH):
#   npm run ingest:leaderboard        — Node, reuses lib/server/leaderboard-scoring.js (same as app)
#   npm run ingest:leaderboard:py     — Python pipeline; pip install -r pipelines/requirements.txt
# AI_LEADERBOARD_SOURCE_PATH=data/ai-leaderboard-source.json
# Fetch+ingest Edison NJ salons: npm run ingest:edison:py (needs GOOGLE_PLACES_API_KEY + Supabase). Dry-run JSON only: python3 pipelines/fetch_ingest_edison_nj_salons.py --dry-run
# Optional: POST /api/leaderboard/refresh-salon — set secret OR use admin Bearer token.
LEADERBOARD_REFRESH_SECRET=

APP_BASE_URL=https://review.yourdomain.com
# Shopify token for server-side checkout creation.
# On Vercel, add this in Project Settings -> Environment Variables.
# Optional alias supported by code: VERCEL_SHOPIFY_STOREFRONT_ACCESS_TOKEN
# Keep real values in .env.local (local) or hosting provider secret settings.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Google Places API (New) — store + nearby competitor report (/api/store-map-report).
# Enable "Places API (New)" on the same Google Cloud project.
GOOGLE_PLACES_API_KEY=
# Optional: if set, POST /api/store-map-report requires Authorization: Bearer <secret> or header x-tool-secret
STORE_MAP_REPORT_SECRET=

# Tavus / Ryan assistant.
# Set these in `.env.local` or your deployment environment only.
# Never commit real keys into tracked files or repo docs.
TAVUS_API_KEY=
NEXT_PUBLIC_TAVUS_API_KEY=
PIPECAT_BACKEND_URL=
NEXT_PUBLIC_BACKEND_URL=

# Optional values for scripts/seed-menu-snapshot.js
STORE_SLUG=
MENU_VERSION=1
MENU_FILE=./menu.json
SOURCE_NOTE=Seeded from local menu.json
